# ==============================================================================
# Shield API - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.

# GENERAL
PORT=3000
FRONTEND_URL=http://localhost:3001

# DATABASE (PostgreSQL with RLS — matches docker-compose.yml defaults)
DATABASE_URL=postgresql://shield_api:asdf@localhost:5432/shield_api?schema=public

# AUTH (Keycloak OIDC — defaults point to staging)
AUTH_JWKS_URI=https://auth.stg.fc-safety.com/realms/shield/protocol/openid-connect/certs
AUTH_ISSUER=https://auth.stg.fc-safety.com/realms/shield
AUTH_AUDIENCE=shield-api

# KEYCLOAK ADMIN CLIENT (staging — get credentials from team)
KEYCLOAK_ADMIN_CLIENT_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_DEFAULT_REALM=shield
KEYCLOAK_ADMIN_CLIENT_BASE_URL=https://auth.stg.fc-safety.com
KEYCLOAK_ADMIN_CLIENT_CLIENT_ID=shield-api
KEYCLOAK_ADMIN_CLIENT_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_REFRESH_INTERVAL_SECONDS=58
KEYCLOAK_WEBHOOK_SECRET=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001

# EMAIL (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# SMS (Telnyx)
TELNYX_API_KEY=KEY_xxxxxxxxxxxx
TELNYX_PHONE_NUMBER=+15555555555

# REDIS / VALKEY
KV_STORE_HOST=localhost
KV_STORE_PORT=6379
KV_STORE_CONNECT_TIMEOUT=5000

# CLOUDFLARE TURNSTILE (Bot Protection)
CLOUDFLARE_TURNSTILE_SECRET_KEY_SHIELD_LANDING=

# SIGNING (HMAC signing keys for tags/custom tokens)
DEFAULT_SIGNING_KEY_ID=default

# SHIELD LANDING
BCC_LEAD_FORM_SUBMISSION_EMAILS=

# HELP SCOUT (Support widget)
HELPSCOUT_BEACON_SECRET_KEY=

# M2M API KEYS (Machine-to-machine, comma-separated)
M2M_API_KEYS=

# LEGACY MIGRATION (MySQL - optional)
LEGACY_DB_HOST=
LEGACY_DB_USER=
LEGACY_DB_PASSWORD=
LEGACY_DB_NAME=
LEGACY_DB_PORT=3306

# STARTUP OPTIONS
SYNC_KEYCLOAK_ACCESS_ON_STARTUP=false

# SYSTEM ADMIN EMAILS (comma-separated, for bootstrap admin access)
SYSTEM_ADMIN_EMAILS=

# LOGGING
LOG_LEVEL=error
